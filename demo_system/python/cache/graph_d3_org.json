    {
      "id": "team:nop_project",
      "label": "NOP Risk Model Project Team",
      "type": "team",
      "group": 5,
      "size": 12,
      "meta": {
        "goal": "Modernize the dangerous goods site inspection risk scoring model to improve detection rates, reduce false negatives, and maintain budget neutrality through the STRL-2026 streamlining filter.",
        "description": "Cross-functional team responsible for the 2026-27 modernization of the National Occupational Profile (NOP) risk model used to prioritize dangerous goods site inspections across Canada. The team rebuilt the model from a failing 2015 baseline (14% false negative rate) to a fully compliant, audited production system.",
        "lead": "Sean"
      }
    },
    {
      "id": "team:data_technical",
      "label": "Data & Technical Sub-team",
      "type": "team",
      "group": 5,
      "size": 8,
      "meta": {
        "goal": "Own TDG_CORE database integrity, SAS model implementation, and all data governance for the risk model.",
        "description": "Responsible for data quality, model coding, and technical validation. This sub-team identified and remediated the 1900-01-01 legacy data decay issue affecting 11,240 records, produced the production SAS model, and ran UAT parallel validation before go-live.",
        "lead": "Carolyn"
      }
    }
